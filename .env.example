# OpenAI API Key (required for AI features)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Serper API Key (optional - for web search fallback)
SERPER_API_KEY=

# LiteLLM Configuration (optional)
LITELLM_LOG=DEBUG
LITELLM_MAX_RETRIES=3

# Envio Configuration
ENVIO_DEFAULT_PACKAGE_MANAGER=pip
ENVIO_DEFAULT_PYTHON_VERSION=3.11
ENVIO_LOG_LEVEL=INFO
